samples_metadata <- read.csv("/mnt/DATA2/cfDNA_finaledb/metadata.tsv", sep = "\t", header = TRUE)

merged <- read.csv("/mnt/DATA3/block_course/tf_profiling/results/final_results_corrected.tsv", sep = "\t", header = TRUE)

markers <- read.csv("/mnt/DATA3/block_course/Mateusz/marker_tfs.tsv", sep = "\t", header = TRUE, stringsAsFactors = TRUE)

# -----------------------------------------------------------------------------
# Preprocess Metadata
# -----------------------------------------------------------------------------

# Add cancer presence label and restrict to cfDNA samples
samples_metadata <- samples_metadata %>%
  mutate(Cancer.presence = ifelse(Patient.Type == "Healthy", "Healthy", "Cancer")) %>%
  mutate(Cancer.presence = as.factor(Cancer.presence)) %>%
  filter(Sample.Type == "cfDNA") %>%
  filter(Patient.Type != "Duodenal Cancer")

# -----------------------------------------------------------------------------
# Build Feature Matrices
# -----------------------------------------------------------------------------

merged <- merged %>% mutate(ratio = central_coverage / mean_coverage)

mean_cov_df <- merged %>%
  select(TF, sample, mean_coverage) %>%
  pivot_wider(names_from = sample, values_from = mean_coverage)

central_cov_df <- merged %>%
  select(TF, sample, central_coverage) %>%
  pivot_wider(names_from = sample, values_from = central_coverage)

amplitude_df <- merged %>%
  select(TF, sample, amplitude) %>%
  pivot_wider(names_from = sample, values_from = amplitude)

# -----------------------------------------------------------------------------
# Helper: Prepare limma Inputs
# -----------------------------------------------------------------------------

# Aligns the feature matrix with a metadata subset, recodes Patient.Type,
# and returns a list with the expression matrix and matched metadata.

prepare_limma_inputs <- function(central_cov_df, meta) {
  mat <- central_cov_df %>%
    column_to_rownames("TF") %>%
    as.matrix()

  common_samples <- intersect(colnames(mat), meta$sample)
  cat("Number of common samples:", length(common_samples), "\n")

  mat <- mat[, common_samples, drop = FALSE]
  meta_sub <- meta[meta$sample %in% common_samples, ]
  meta_sub <- meta_sub[match(colnames(mat), meta_sub$sample), ]

  cat("Matrix columns:", ncol(mat), "\n")
  cat("Metadata rows:", nrow(meta_sub), "\n")
  cat("Names match:", all(colnames(mat) == meta_sub$sample), "\n")

  if (any(is.na(meta_sub$sample))) stop("NAs found in metadata after matching!")

  meta_sub$Patient.Type <- fct_recode(
    meta_sub$Patient.Type,
    TumorA           = "Tumor A",
    Healthy          = "Healthy",
    Breast_Cancer    = "Breast Cancer",
    Lung_Cancer      = "Lung Cancer",
    TumorB           = "Tumor B",
    Pancreatic_Cancer = "Pancreatic Cancer",
    Bile_Duct_Cancer = "Bile Duct Cancer",
    Gastric_Cancer   = "Gastric cancer"
  )

  meta_sub$Patient.Type <- factor(
    meta_sub$Patient.Type,
    levels = c("Healthy", "TumorA", "TumorB", "Breast_Cancer",
               "Lung_Cancer", "Pancreatic_Cancer", "Bile_Duct_Cancer", "Gastric_Cancer")
  )

  list(emat = mat, meta_sub = meta_sub)
}

# -----------------------------------------------------------------------------
# Helper: Run Per-Cancer-Type limma
# -----------------------------------------------------------------------------

run_limma_cancer_types <- function(emat, meta_sub) {
  design <- model.matrix(~ 0 + Patient.Type + tfx, data = meta_sub)
  patient_type_cols <- grep("^Patient\\.Type", colnames(design))
  colnames(design)[patient_type_cols] <- levels(meta_sub$Patient.Type)

  contr <- makeContrasts(
    Colorectal  = TumorA - Healthy,
    Ovarian     = TumorB - Healthy,
    Breast      = Breast_Cancer - Healthy,
    Lung        = Lung_Cancer - Healthy,
    Pancreatic  = Pancreatic_Cancer - Healthy,
    Bile        = Bile_Duct_Cancer - Healthy,
    Gastric     = Gastric_Cancer - Healthy,
    levels = design
  )

  fit <- lmFit(emat, design)
  fit <- contrasts.fit(fit, contr)
  fit <- eBayes(fit, robust = TRUE)

  all_results <- lapply(colnames(contr), function(contrast_name) {
    res <- topTreat(fit, coef = contrast_name, number = Inf)
    res$FC <- 2^(res$logFC)
    res$percentChange <- (res$FC - 1) * 100
    res
  })
  names(all_results) <- colnames(contr)

  cat("Available results:", names(all_results), "\n")
  all_results
}

# -----------------------------------------------------------------------------
# Analysis 1: All Samples (no tfx filter)
# -----------------------------------------------------------------------------

inputs_all <- prepare_limma_inputs(central_cov_df, samples_metadata)
all_results <- run_limma_cancer_types(inputs_all$emat, inputs_all$meta_sub)

# -----------------------------------------------------------------------------
# Analysis 2: tfx-filtered Samples (tfx > 0.03 for cancer, all healthy)
# -----------------------------------------------------------------------------

meta_filtered <- samples_metadata %>%
  filter(
    (Cancer.presence == "Cancer" & tfx > 0.03) |
    (Cancer.presence == "Healthy")
  )

inputs_filt <- prepare_limma_inputs(central_cov_df, meta_filtered)
all_results_filtered <- run_limma_cancer_types(inputs_filt$emat, inputs_filt$meta_sub)

# -----------------------------------------------------------------------------
# Analysis 3: Cancer vs. Healthy (binary, no tfx covariate)
# -----------------------------------------------------------------------------

mat_bin <- central_cov_df %>% column_to_rownames("TF") %>% as.matrix()
common_bin  <- intersect(colnames(mat_bin), samples_metadata$sample)
mat_bin     <- mat_bin[, common_bin, drop = FALSE]
meta_bin    <- samples_metadata[match(common_bin, samples_metadata$sample), ]

meta_bin$Cancer.presence <- factor(meta_bin$Cancer.presence, levels = c("Healthy", "Cancer"))
design_bin <- model.matrix(~ 0 + Cancer.presence, data = meta_bin)
colnames(design_bin) <- levels(meta_bin$Cancer.presence)

contr_bin <- makeContrasts(Cancer.vs.Healthy = Cancer - Healthy, levels = design_bin)

fit_bin <- lmFit(mat_bin, design_bin)
fit_bin <- contrasts.fit(fit_bin, contr_bin)
fit_bin <- eBayes(fit_bin, robust = TRUE)

res_binary <- topTreat(fit_bin, coef = "Cancer.vs.Healthy", number = Inf)
res_binary$FC           <- 2^(res_binary$logFC)
res_binary$percentChange <- (res_binary$FC - 1) * 100

# -----------------------------------------------------------------------------
# Volcano Plot Helper
# -----------------------------------------------------------------------------

plot_volcano <- function(df, title, use_adj = FALSE) {
  y_var  <- if (use_adj) "adj.P.Val" else "P.Value"
  color  <- if (use_adj) "red" else "green"
  y_lab  <- if (use_adj) "-log10(FDR)" else "-log10(p-value)"

  df$y_val   <- -log10(df[[y_var]])
  df$sig     <- df[[y_var]] < 0.05

  ggplot(df, aes(x = logFC, y = y_val)) +
    geom_point(aes(color = sig), alpha = 0.7, size = 2) +
    scale_color_manual(values = c("gray", color)) +
    geom_vline(xintercept = 0, linetype = "dashed") +
    geom_hline(yintercept = -log10(0.05), linetype = "dotted") +
    labs(x = "log2 Fold Change (Cancer – Healthy)", y = y_lab, title = title) +
    theme_bw() +
    theme(
      axis.text  = element_text(size = 10),
      axis.title = element_text(size = 15),
      plot.title = element_text(size = 15, face = "bold")
    )
}

# Plot all per-cancer-type contrasts (nominal p-value)
for (cancer in names(all_results)) {
  print(plot_volcano(all_results[[cancer]], paste(cancer, "- Differential TF accessibility"), use_adj = FALSE))
}

# Plot all per-cancer-type contrasts (FDR)
for (cancer in names(all_results)) {
  print(plot_volcano(all_results[[cancer]], paste(cancer, "- Differential TF accessibility"), use_adj = TRUE))
}

# Save example plot
plot_volcano(all_results[["Colorectal"]], "Colorectal Cancer - Differential TF accessibility", use_adj = TRUE)
ggsave("diff_plot_colorectal.png", dpi = 600, width = 10, height = 7)


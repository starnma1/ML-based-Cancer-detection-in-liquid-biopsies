# -----------------------------------------------------------------------------
# Marker TF Heatmap (filtered results)
# -----------------------------------------------------------------------------

# Build logFC matrix for marker TFs across all cancer types
all_sig_tfs <- unique(markers$TF)

merged_df <- map_df(all_results_filtered, ~ {
  .x %>%
    as.data.frame() %>%
    rownames_to_column("TF") %>%
    select(TF, logFC) %>%
    filter(TF %in% all_sig_tfs)
}, .id = "Cancer")

final_df <- merged_df %>%
  pivot_wider(names_from = Cancer, values_from = logFC)

mat_markers <- final_df %>%
  column_to_rownames("TF") %>%
  as.matrix()

mat_markers_scaled <- t(scale(t(mat_markers)))

# Hierarchical clustering
row_dist <- dist(mat_markers_scaled, method = "euclidean")
col_dist <- dist(t(mat_markers_scaled), method = "euclidean")
row_hc   <- hclust(row_dist, method = "complete")
col_hc   <- hclust(col_dist, method = "complete")

pheatmap(
  mat_markers_scaled[row_hc$order, col_hc$order],
  cluster_rows     = FALSE,
  cluster_cols     = FALSE,
  color            = colorRampPalette(c("blue", "white", "red"))(50),
  main             = "Marker TF Accessibility Heatmap (Hierarchical Clustered)",
  na_col           = "grey90"
)

# -----------------------------------------------------------------------------
# All-TF Heatmap (all_results logFC, first column per cancer)
# -----------------------------------------------------------------------------

combined_df <- bind_cols(
  lapply(names(all_results), function(cancer) {
    df <- all_results[[cancer]][, 1, drop = FALSE]
    colnames(df) <- cancer
    df
  })
)

combined_scaled <- t(scale(t(combined_df)))

row_hc2 <- hclust(dist(combined_scaled),   method = "complete")
col_hc2 <- hclust(dist(t(combined_scaled)), method = "complete")

pheatmap(
  combined_scaled,
  color          = colorRampPalette(c("blue", "white", "red"))(100),
  breaks         = seq(-2, 2, length.out = 101),
  cluster_rows   = row_hc2,
  cluster_cols   = col_hc2,
  show_rownames  = FALSE,
  show_colnames  = TRUE,
  fontsize_col   = 14,
  fontsize_main  = 16,
  main           = "TF Accessibility Heatmap (All TFs, Hierarchical Clustered)",
  legend_breaks  = c(-2, -1, 0, 1, 2),
  legend_labels  = c("-2", "-1", "0", "1", "2"),
  treeheight_row = 0,
  treeheight_col = 0,
  width          = 10,
  height         = 14
)


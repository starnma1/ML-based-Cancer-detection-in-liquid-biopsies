  mutate(
    tfx_bin = factor(ifelse(tfx < 0.02, "< 0.02", "≥ 0.02"), levels = c("< 0.02", "≥ 0.02"))
  )

ggplot(df_pca, aes(PC1, PC2, color = Patient.Type, shape = tfx_bin)) +

def finding_best_model(models):
    C_series = pd.Series(models["C parameters"])
    PCA_series = pd.Series(models["PCA components"])
    trainAUC = np.array(models["train AUC"])
    trainACC = np.array(models["train accuracy"])
    testAUC  = np.array(models["test AUC"])
    testACC  = np.array(models["test accuracy"])

    # modes
    our_c = C_series.mode().iloc[0]
    our_n = PCA_series.mode().iloc[0]

    # means + CI
    our_train_AUC = trainAUC.mean()
    lower_train_AUC, upper_train_AUC = np.quantile(trainAUC, [0.025, 0.975])

    our_train_ACC = trainACC.mean()
    lower_train_ACC, upper_train_ACC = np.quantile(trainACC, [0.025, 0.975])

    our_test_AUC = testAUC.mean()
    lower_test_AUC, upper_test_AUC = np.quantile(testAUC, [0.025, 0.975])

    our_test_ACC = testACC.mean()
    lower_test_ACC, upper_test_ACC = np.quantile(testACC, [0.025, 0.975])

    print("Our cool report:\n"
          f"C hyperparameter: {our_c}\n"
          f"PCA components: {our_n}\n"
          f"train AUC confidence:  [{lower_train_AUC:.3f}, {our_train_AUC:.3f}, {upper_train_AUC:.3f}]\n"
          f"train ACC confidence:  [{lower_train_ACC:.3f}, {our_train_ACC:.3f}, {upper_train_ACC:.3f}]\n"
          f"test AUC confidence:   [{lower_test_AUC:.3f}, {our_test_AUC:.3f}, {upper_test_AUC:.3f}]\n"
          f"test ACC confidence:   [{lower_test_ACC:.3f}, {our_test_ACC:.3f}, {upper_test_ACC:.3f}]"
    )

    return our_c, our_n


